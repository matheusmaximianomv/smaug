generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Placeholder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

// Base schema only; business models will be added in future features.
// Reminder: re-run `npx prisma generate` after changing DATABASE_PROVIDER between
// postgresql and sqlite because the client is generated per provider.
